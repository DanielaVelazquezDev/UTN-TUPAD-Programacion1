# 1) Definimos credenciales fijas
USUARIO_CORRECTO = "alumno"
CLAVE_CORRECTA = "python123"

# Variables de control
intentos = 1
acceso_concedido = False

# 2) Bucle de Login (Máximo 3 intentos)
while intentos <= 3 and not acceso_concedido:
    print(f"\nIntento {intentos}/3")
    user_input = input("Usuario: ")
    pass_input = input("Clave: ")
    
    if user_input == USUARIO_CORRECTO and pass_input == CLAVE_CORRECTA:
        print("Acceso concedido.")
        acceso_concedido = True
    else:
        print("Error: credenciales inválidas.")
        intentos += 1

# 3) Verificamos si se bloqueó la cuenta
if not acceso_concedido:
    print("\nCuenta bloqueada.")
else:
    # 4) Menú repetitivo
    opcion = ""
    while opcion != "4":
        print("\n--- MENÚ DEL CAMPUS ---")
        print("1) Ver estado de inscripción")
        print("2) Cambiar clave")
        print("3) Mostrar mensaje motivacional")
        print("4) Salir")
        
        opcion = input("Opción: ")
        
        # 5) Validación de la opción (debe ser número entre 1 y 4)
        if not opcion.isdigit():
            print("Error: ingrese un número válido.")
            continue # Salta al inicio del while
        
        if not (1 <= int(opcion) <= 4):
            print("Error: opción fuera de rango.")
            continue

        # Lógica de las opciones
        if opcion == "1":
            print("Estado: Inscripto")
            
        elif opcion == "2":
            # Cambio de clave con validación de longitud y confirmación
            nueva_clave = input("Nueva clave (mínimo 6 caracteres): ")
            
            while len(nueva_clave) < 6:
                print("Error: mínimo 6 caracteres.")
                nueva_clave = input("Nueva clave: ")
                
            confirmacion = input("Confirme su nueva clave: ")
            
            if nueva_clave == confirmacion:
                CLAVE_CORRECTA = nueva_clave
                print("Clave cambiada con éxito.")
            else:
                print("Error: las claves no coinciden. No se realizó el cambio.")
                
        elif opcion == "3":
            print("Mensaje: 'El éxito es la suma de pequeños esfuerzos repetidos día tras día.'")
            
    print("Has salido del sistema.")
